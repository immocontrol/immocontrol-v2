# ─── Supabase ───
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ─── DeepSeek AI (optional) ───
# If set, Immo-Chat and KI-Tipp use DeepSeek API. Otherwise Supabase Edge Function immo-ai-chat is used.
# Get key: https://platform.deepseek.com → API Keys
# VITE_DEEPSEEK_API_KEY="sk-..."

# ─── Manus AI (optional — only for local dev without server-side proxy) ───
# In production, set MANUS_API_KEY as a Supabase Secret instead.
# The Edge Function "manus-proxy" will use the server-side secret.
# VITE_MANUS_API_KEY="manus_..."
